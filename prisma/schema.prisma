generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts   Account[]
  sessions   Session[]
  leads      Lead[]
  activities Activity[]
}

enum LeadStatus {
  OUTREACH
  COFFEE
  PROPOSAL
  QUOTE
  WON
  LOST
}

enum LeadSource {
  LINKEDIN
  EVENT
  REFERRAL
  COLD_EMAIL
  WEBSITE
  OTHER
}

enum GoldfizjService {
  AI_STRATEGY
  CHANGE_MANAGEMENT
  DIGITAL_TRANSFORMATION
  ORGANIZATIONAL_DESIGN
  LEADERSHIP_DEVELOPMENT
  OTHER
}

model Lead {
  id          String          @id @default(cuid())
  name        String
  linkedinUrl String?
  company     String?
  role        String?
  source      LeadSource      @default(LINKEDIN)
  service     GoldfizjService @default(AI_STRATEGY)
  status      LeadStatus      @default(OUTREACH)
  notes       String?         @db.Text
  aiSummary   String?         @db.Text
  aiScore     Int?
  aiEnriched  Boolean         @default(false)
  convertedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  ownerId    String
  owner      User       @relation(fields: [ownerId], references: [id])
  activities Activity[]
}

model Activity {
  id         String      @id @default(cuid())
  type       String
  fromStatus LeadStatus?
  toStatus   LeadStatus?
  note       String?     @db.Text
  createdAt  DateTime    @default(now())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])
}
